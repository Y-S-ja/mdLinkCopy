{
    "manifest_version": 3,
    "name": "Quick Md Copy",
    "version": "1.0",
    "description": "アイコンクリックでMarkdownリンクを即座にコピー",
    "permissions": [
        "activeTab",
        "scripting",
        "notifications"
    ],
    "icons": {
        "16": "icon16x16.png",
        "32": "icon32x32.png",
        "48": "icon192x192.png",
        "128": "icon192x192.png",
        "192": "icon192x192.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": {
            "16": "icon16x16.png",
            "24": "icon32x32.png",
            "32": "icon32x32.png",
            "48": "icon192x192.png"
        },
        "default_title": "Quick Md Copy"
    }
}